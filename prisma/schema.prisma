// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
  transfer
}

model UserAuth {
  id String @id @default(cuid())
  login String @unique
  passwordHash String @map("password_hash")
  isFaceIdEnabled Boolean @map("is_face_id_enabled")
  refreshToken String? @map("refresh_token")
  biometricCredentials String? @map("biometric_credentials")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String?   @map("sync_status")
  isDeleted  Boolean?  @map("is_deleted")

  userBank UserBank[]
  userCategorySetting UserCategorySetting[]
  transaction Transaction[]

  @@map("user_auth")
}

model Bank {
  id           String @id @default(cuid())
  name         String
  imageUrl    String @map("image_url") //в коде imageUrl, в бд - image_url

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String?   @map("sync_status")
  isDeleted  Boolean?  @map("is_deleted")

  userBank UserBank[] // совместимость

  @@map("banks")
}

model UserBank {
  id String @id @default(cuid())

  userAuthId String @map("user_auth_id")
  userAuth   UserAuth   @relation(fields: [userAuthId], references: [id], onDelete: Cascade)

  bankId String @map("bank_id")
  bank   Bank   @relation(fields: [bankId], references: [id], onDelete: Cascade)

  displayOrder Int             @map("display_order")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String?   @map("sync_status")
  isDeleted  Boolean?  @map("is_deleted")

  savingAccount SavingAccount[]
  goal Goal[]

  @@map("user_bank")
}

model SavingAccount {
  id String @id @default(cuid())

  userBankId String @map("user_bank_id")
  userBank UserBank @relation(fields: [userBankId], references: [id], onDelete: Cascade)

  name         String
  balance      Decimal
  currencyCode String  @map("currency_code")
  isArchived   Boolean? @map("is_archived") //TODO: xz?

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String?   @map("sync_status")
  isDeleted  Boolean?  @map("is_deleted")

  goals        Goal[]
  transactions Transaction[]

  @@map("saving_accounts")
}

model Goal {
  id String @id @default(cuid())

  userBankId String @map("user_bank_id")
  userBank UserBank @relation(fields: [userBankId], references: [id], onDelete: Cascade)

  title         String
  targetAmount  Decimal  @map("target_amount")
  currentAmount Decimal  @map("current_amount")
  currencyCode  String   @map("currency_code")
  iconUrl      String   @map("icon_url")

  savingsAccountId String?        @map("savings_account_id")
  savingsAccount   SavingAccount? @relation(fields: [savingsAccountId], references: [id], onDelete: SetNull)

  deadlineAt    DateTime @default(now()) @map("deadline_at")
  isCompleted   Boolean  @map("is_completed")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String?   @map("sync_status")
  isDeleted  Boolean?  @map("is_deleted")

  @@map("goals")
}

model Category {
  id           String          @id @default(cuid())
  name         String
  type         TransactionType
  iconName     String          @map("icon_name")
  colorHex     String          @map("color_hex")
  displayOrder Int             @map("display_order")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String?   @map("sync_status")
  isDeleted  Boolean?  @map("is_deleted")

  transactions Transaction[]
  userCategorySetting UserCategorySetting[]

  @@map("category")
}

model UserCategorySetting {
  id String @id @default(cuid())

  userAuthId String @map("user_auth_id")
  userAuth   UserAuth   @relation(fields: [userAuthId], references: [id], onDelete: Cascade)

  categoryId String @map("category_id")
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  isHidden Boolean @map("is_hidden")
  customDisplayOrder Int @map("custom_display_order")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String?   @map("sync_status")
  isDeleted  Boolean?  @map("is_deleted")
}

model Transaction {
  id           String          @id @default(cuid())

  userAuthId String @map("user_auth_id")
  userAuth   UserAuth   @relation(fields: [userAuthId], references: [id], onDelete: Cascade)

  type         TransactionType
  amount        Decimal
  currencyCode String          @map("currency_code")

  savingsAccountId String?        @map("savings_account_id")
  savingsAccount   SavingAccount? @relation(fields: [savingsAccountId], references: [id], onDelete: SetNull)

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  title           String
  note            String?
  transactionDate DateTime @default(now()) @map("transaction_date")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String?   @map("sync_status")
  isDeleted  Boolean?  @map("is_deleted")
}
