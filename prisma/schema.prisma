// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
  transfer
}

model Bank {
  id           String @id @default(cuid())
  name         String
  imageName    String @map("image_name") //в коде imageName, в бд - image_name
  displayOrder Int    @map("display_order")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String   @map("sync_status")
  isDeleted  Boolean  @map("is_deleted")

  savingAccounts SavingAccount[] //обратная связь

  @@map("banks")
}

model SavingAccount {
  id String @id @default(cuid())

  bankId String @map("bank_id")
  bank   Bank   @relation(fields: [bankId], references: [id], onDelete: Cascade)

  name         String
  currencyCode String  @map("currency_code")
  iconName     String  @map("icon_name") //может значение из енамки для отображения карточек банков
  balance      Decimal
  isArchived   Boolean @map("is_archived")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String   @map("sync_status")
  isDeleted  Boolean  @map("is_deleted")

  goals        Goal[]
  transactions Transactions[]

  @@map("saving_accounts")
}

model Goal {
  id String @id @default(cuid())

  savingsAccountId String?        @map("savings_account_id")
  savingsAccount   SavingAccount? @relation(fields: [savingsAccountId], references: [id], onDelete: SetNull)

  title         String
  targetAmount  Decimal  @map("target_amount")
  iconName      String   @map("icon_name")
  currentAmount Decimal  @map("current_amount")
  currencyCode  String   @map("currency_code")
  deadlineAt    DateTime @default(now()) @map("deadline_at")
  isCompleted   Boolean  @map("is_completed")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String   @map("sync_status")
  isDeleted  Boolean  @map("is_deleted")

  @@map("goals")
}

model Category {
  id           String          @id @default(cuid())
  name         String
  type         TransactionType
  iconName     String          @map("icon_name")
  colorHex     String          @map("color_hex")
  displayOrder Int             @map("display_order")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String   @map("sync_status")
  isDeleted  Boolean  @map("is_deleted")

  transactions Transactions[]

  @@map("category")
}

model Transactions {
  id           String          @id @default(cuid())
  type         TransactionType
  amout        Decimal
  currencyCode String          @map("currency_code")

  savingsAccountId String?        @map("savings_account_id")
  savingsAccount   SavingAccount? @relation(fields: [savingsAccountId], references: [id], onDelete: SetNull)

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  title           String
  note            String
  transactionDate DateTime @default(now()) @map("transaction_date")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  syncStatus String   @map("sync_status")
  isDeleted  Boolean  @map("is_deleted")
}
